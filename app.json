{
  "expo": {
    "name": "PawConnect",
    "slug": "PawConnect",
    "version": "1.05.4",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "pawconnectapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PawConnect uses your location to find nearby pet services.",
        "NSCameraUsageDescription": "PawConnect needs camera access to upload pet images.",
        "NSPhotoLibraryUsageDescription": "PawConnect needs access to your photos to upload pet images.",
        "NSMicrophoneUsageDescription": "PawConnect uses the microphone for audio and voice features."
      }
    },
    "android": {
      "package": "com.pawconnect.app",
      "versionCode": 5,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "pawconnectapp",
              "host": "reset-password"
            },
            {
              "scheme": "https",
              "host": "pawconnectbackend.onrender.com",
              "pathPrefix": "/api/v1/auth/reset-password"
            }
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "pawconnectapp",
              "host": "reset-password"
            },
            {
              "scheme": "https",
              "host": "pawconnectbackend.onrender.com",
              "pathPrefix": "/api/v1/auth/reset-password"
            }
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-audio",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF6B35"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1c49bcad-3aa2-492f-96be-ab67b02de5f0"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1c49bcad-3aa2-492f-96be-ab67b02de5f0"
    }
  }
}
